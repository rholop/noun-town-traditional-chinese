# This repo is rooted in a "Noun Town Language Learning" game install.
# Track only the mod project (mod/) plus repo-level docs; ignore the game's
# own files, BepInEx runtime, build artifacts, and generated/intermediate
# mod data (regenerated by mod/scripts/build_all.sh against a target game).
/*
!/.gitignore
!/README.md
!/install.sh
!/install.ps1
!/install.bat
!/mod/

/mod/plugin/NounTownZhTW/bin/
/mod/plugin/NounTownZhTW/obj/
/mod/scripts/__pycache__/
/mod/extracted/
/mod/zh-TW/
/mod/shadow/
/mod/package/dist/
